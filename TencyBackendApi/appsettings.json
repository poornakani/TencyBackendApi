{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "Jwt": {
    "Key": "#{JWT_KEY_OVERRIDE_VIA_USER_SECRETS}#",
    "Issuer": "TenzyBackend",
    "Audience": "TenzyFrontend"
  },

  "RateLimit": {
    "AuthMaxAttempts": 5,
    "AuthWindowSeconds": 60
  }
}
